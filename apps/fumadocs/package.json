{
  "name": "fumadocs",
  "private": true,
  "type": "module",
  "sideEffects": false,
  "scripts": {
    "dev": "vite dev --port=4000",
    "build": "bun scripts/fetch-notra-posts.ts && vite build && bun scripts/ensure-root-index.ts",
    "posts:fetch": "bun scripts/fetch-notra-posts.ts",
    "start": "serve .output/public --config ../../serve.json",
    "preview": "vite preview",
    "test": "bun test",
    "types:check": "fumadocs-mdx && tsc --noEmit",
    "postinstall": "fumadocs-mdx"
  },
  "dependencies": {
    "@orama/orama": "^3.1.18",
    "@tanstack/react-router": "1.170.8",
    "@tanstack/react-router-devtools": "1.167.0",
    "@tanstack/react-start": "1.168.13",
    "@tanstack/start-static-server-functions": "1.167.9",
    "@usenotra/sdk": "^1.3.1",
    "@vercel/analytics": "^2.0.1",
    "fumadocs-core": "16.9.1",
    "fumadocs-mdx": "15.0.9",
    "fumadocs-ui": "16.9.1",
    "lucide-react": "^1.23.0",
    "marked": "^18.0.5",
    "posthog-js": "^1.386.6",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "sanitize-html": "^2.17.5",
    "shiki": "4.1.0",
    "tailwind-merge": "^3.6.0",
    "vite": "^8.1.3"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.2",
    "@types/mdx": "^2.0.14",
    "@types/node": "^25.9.4",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/sanitize-html": "^2.16.1",
    "@vitejs/plugin-react": "^6.0.3",
    "nitro": "3.0.260522-beta",
    "serve": "^14.2.6",
    "srvx": "^0.11.20",
    "tailwindcss": "^4.3.2",
    "typescript": "^6.0.3"
  }
}
