{
  "name": "@opencoredev/email-sdk-mcp",
  "version": "0.0.0",
  "description": "A secure stdio MCP server for Email SDK.",
  "keywords": [
    "ai-agents",
    "email",
    "email-sdk",
    "mcp",
    "model-context-protocol"
  ],
  "homepage": "https://email-sdk.dev",
  "bugs": {
    "url": "https://github.com/opencoredev/email-sdk/issues"
  },
  "license": "AGPL-3.0-only",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/opencoredev/email-sdk.git",
    "directory": "packages/email-sdk-mcp"
  },
  "bin": {
    "email-sdk-mcp": "dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "src"
  ],
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./stdio": {
      "types": "./dist/stdio.d.ts",
      "import": "./dist/stdio.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.json && chmod +x dist/cli.js",
    "check-types": "tsc -p tsconfig.json --noEmit",
    "test": "bun test",
    "prepack": "bun run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@opencoredev/email-sdk": "^1.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bun": "^1.3.4",
    "@types/node": "^25.9.4"
  },
  "engines": {
    "bun": ">=1.1.0",
    "node": ">=20.0.0"
  }
}
