{
  "name": "@opencoredev/convex-email",
  "version": "0.1.0",
  "private": true,
  "description": "Convex Email Ops: provider-portable transactional email with durable queues, retries, fallback adapters, idempotency, webhooks, and reactive status.",
  "keywords": [
    "convex",
    "convex-component",
    "email",
    "brevo",
    "cloudflare",
    "iterable",
    "mailgun",
    "mailersend",
    "mailpace",
    "mailtrap",
    "plunk",
    "postmark",
    "resend",
    "scaleway",
    "sequenzy",
    "sendgrid",
    "sparkpost",
    "ses",
    "smtp",
    "unosend",
    "zeptomail",
    "transactional-email"
  ],
  "homepage": "https://email-sdk.dev/docs/components/convex-email",
  "bugs": {
    "url": "https://github.com/opencoredev/email-sdk/issues"
  },
  "license": "AGPL-3.0-only",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/opencoredev/email-sdk.git",
    "directory": "packages/convex-email"
  },
  "files": [
    "dist",
    "src",
    "!src/**/*.test.ts",
    "!src/email-sdk-shim.d.ts",
    "README.md"
  ],
  "type": "module",
  "sideEffects": false,
  "module": "./dist/client/index.js",
  "types": "./dist/client/index.d.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./dist/client/index.d.ts",
      "import": "./dist/client/index.js"
    },
    "./testing": {
      "types": "./dist/testing.d.ts",
      "import": "./dist/testing.js"
    },
    "./test": {
      "types": "./dist/testing.d.ts",
      "import": "./dist/testing.js"
    },
    "./convex.config.js": {
      "types": "./dist/component/convex.config.d.ts",
      "import": "./dist/component/convex.config.js"
    },
    "./convex.config": {
      "types": "./dist/component/convex.config.d.ts",
      "import": "./dist/component/convex.config.js"
    },
    "./_generated/component.js": {
      "types": "./dist/component/_generated/component.d.ts",
      "import": "./dist/component/_generated/component.js"
    },
    "./_generated/component": {
      "types": "./dist/component/_generated/component.d.ts",
      "import": "./dist/component/_generated/component.js"
    }
  },
  "scripts": {
    "codegen": "convex codegen --component-dir src/component",
    "build": "rm -rf dist && tsc -p tsconfig.json",
    "check-types": "tsc -p tsconfig.json --noEmit",
    "test": "bun test",
    "prepack": "bun run build"
  },
  "devDependencies": {
    "@types/bun": "^1.3.4",
    "convex": "^1.36.1",
    "convex-test": "0.0.53"
  },
  "peerDependencies": {
    "@opencoredev/email-sdk": "^0.6.1",
    "convex": "^1.36.1"
  },
  "engines": {
    "bun": ">=1.1.0",
    "node": ">=20.0.0"
  }
}
