# Copy to .env or export these in your shell before running live provider smoke tests.
# Do not commit real provider keys.

LIVE_EMAIL_TO=leodoesdev@gmail.com
LIVE_EMAIL_FROM=
LIVE_EMAIL_SUBJECT_PREFIX=Email SDK live smoke

