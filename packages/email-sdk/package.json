      "import": "./dist/ai.js"
    },
    "./react": {
      "types": "./dist/react.d.ts",
      "import": "./dist/react.js"
    },
    "./plugins/defaults": {
      "types": "./dist/plugins-defaults.d.ts",
      "import": "./dist/plugins-defaults.js"
    },
    "./plugins/observability": {
      "types": "./dist/plugins-observability.d.ts",
      "import": "./dist/plugins-observability.js"
    },
    "./plugins/capture": {
      "types": "./dist/plugins-capture.d.ts",
      "import": "./dist/plugins-capture.js"
    },
    "./plugins/routing": {
      "types": "./dist/plugins-routing.d.ts",
      "import": "./dist/plugins-routing.js"
    },
    "./plugins/timeout": {
      "types": "./dist/plugins-timeout.d.ts",
      "import": "./dist/plugins-timeout.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.json && chmod +x dist/cli.js",
    "check-types": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.type-tests.json",
    "test": "bun test",
    "prepack": "bun run build"
  },
  "devDependencies": {
    "@react-email/render": "^2.1.0",
    "@types/bun": "^1.3.4",
    "@types/node": "^25.9.4",
    "@types/react": "^19.2.17",
    "ai": "^7.0.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "peerDependencies": {
    "@react-email/render": "^2.1.0",
    "ai": "^6.0.182 || ^7.0.0",
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "peerDependenciesMeta": {
    "@react-email/render": {
      "optional": true
    },
    "ai": {
      "optional": true
    },
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    }
  },
  "engines": {
    "bun": ">=1.1.0",
    "node": ">=20.0.0"
  }
}
