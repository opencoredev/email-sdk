{
  "name": "@opencoredev/email-sdk",
  "version": "1.0.0",
  "description": "A TypeScript email SDK for unified transactional sending.",
  "keywords": [
    "bun",
    "email",
    "email-sdk",
    "iterable",
    "mailgun",
    "postmark",
    "resend",
    "sendgrid",
    "sequenzy",
    "ses",
    "smtp",
    "transactional-email",
    "typescript",
    "unosend"
  ],
  "homepage": "https://email-sdk.dev",
  "bugs": {
    "url": "https://github.com/opencoredev/email-sdk/issues"
  },
  "license": "AGPL-3.0-only",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/opencoredev/email-sdk.git",
    "directory": "packages/email-sdk"
  },
  "bin": {
    "email-sdk": "dist/cli.js"
  },
  "files": [
    "dist",
    "src/**/*.ts",
    "src/**/*.tsx",
    "!src/**/*.test.ts",
    "README.md"
  ],
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./resend": {
      "types": "./dist/resend.d.ts",
      "import": "./dist/resend.js"
    },
    "./postmark": {
      "types": "./dist/postmark.d.ts",
      "import": "./dist/postmark.js"
    },
    "./sendgrid": {
      "types": "./dist/sendgrid.d.ts",
      "import": "./dist/sendgrid.js"
    },
    "./cloudflare": {
      "types": "./dist/cloudflare.d.ts",
      "import": "./dist/cloudflare.js"
    },
    "./unosend": {
      "types": "./dist/unosend.d.ts",
      "import": "./dist/unosend.js"
    },
    "./iterable": {
      "types": "./dist/iterable.d.ts",
      "import": "./dist/iterable.js"
    },
    "./ses": {
      "types": "./dist/ses.d.ts",
      "import": "./dist/ses.js"
    },
    "./mailgun": {
      "types": "./dist/mailgun.d.ts",
      "import": "./dist/mailgun.js"
    },
    "./mailersend": {
      "types": "./dist/mailersend.d.ts",
      "import": "./dist/mailersend.js"
    },
    "./brevo": {
      "types": "./dist/brevo.d.ts",
      "import": "./dist/brevo.js"
    },
    "./mailchimp": {
      "types": "./dist/mailchimp.d.ts",
      "import": "./dist/mailchimp.js"
    },
    "./sparkpost": {
      "types": "./dist/sparkpost.d.ts",
      "import": "./dist/sparkpost.js"
    },
    "./loops": {
      "types": "./dist/loops.d.ts",
      "import": "./dist/loops.js"
    },
    "./sequenzy": {
      "types": "./dist/sequenzy.d.ts",
      "import": "./dist/sequenzy.js"
    },
    "./jetemail": {
      "types": "./dist/jetemail.d.ts",
      "import": "./dist/jetemail.js"
    },
    "./lettermint": {
      "types": "./dist/lettermint.d.ts",
      "import": "./dist/lettermint.js"
    },
    "./primitive": {
      "types": "./dist/primitive.d.ts",
      "import": "./dist/primitive.js"
